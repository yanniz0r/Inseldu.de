# MXRoute SMTP API — https://docs.mxroute.com/docs/api/smtp-api.html
# Server hostname from your MXRoute control panel (Email Clients page)
MXROUTE_SERVER=tuesday.mxrouting.net
MXROUTE_USER=hello@yourdomain.com
MXROUTE_PASS=your-email-password

# The address emails are sent from (must be an address on your MXRoute account)
MXROUTE_FROM=hello@yourdomain.com

# The address that receives contact form submissions
CONTACT_TO=hello@yourdomain.com
